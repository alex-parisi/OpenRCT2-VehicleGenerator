{
  "version": 3,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Dev (IDE / compile_commands.json)",
      "description": "Debug build in native/build/ with compile_commands.json for clangd and tests enabled. Run once after cloning, then re-run when CMakeLists.txt changes.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "BUILD_PYTHON_MODULE": "OFF",
        "CMAKE_PREFIX_PATH": "/opt/homebrew"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": { "outputOnFailure": true }
    }
  ]
}
