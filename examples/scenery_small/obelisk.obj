# Simple obelisk (tapered box) for the small-scenery example.
# OBJ space: +X forward, +Y up, +Z right. Origin at the footprint-base centre
# so it sits on the tile. Footprint ~1.5x1.5 units, ~2.6 units tall (< 1 tile
# = 3.3 units wide), tapering toward the top.
mtllib materials.mtl

# Base ring (y = 0), half-extent 0.75
v -0.75 0.0 -0.75
v  0.75 0.0 -0.75
v  0.75 0.0  0.75
v -0.75 0.0  0.75
# Top ring (y = 2.6), half-extent 0.28 (taper)
v -0.28 2.6 -0.28
v  0.28 2.6 -0.28
v  0.28 2.6  0.28
v -0.28 2.6  0.28

vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0

usemtl Remap1

# Bottom
f 1//1 2//1 3//1
f 1//1 3//1 4//1
# Top
f 5//2 7//2 6//2
f 5//2 8//2 7//2
# -Z face
f 1//3 5//3 6//3
f 1//3 6//3 2//3
# +Z face
f 4//4 3//4 7//4
f 4//4 7//4 8//4
# -X face
f 1//5 4//5 8//5
f 1//5 8//5 5//5
# +X face
f 2//6 6//6 7//6
f 2//6 7//6 3//6
